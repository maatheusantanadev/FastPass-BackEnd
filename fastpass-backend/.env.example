APP_NAME=FastPass
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Bahia
APP_URL=http://localhost:8000

# Origem da SPA (front-end) autorizada no CORS. Em dev o Vite roda em 5173.
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ------------------------------------------------------------------
# Banco de Dados - Supabase (PostgreSQL)
# Preencha com as credenciais do seu projeto. NUNCA versione o .env.
# Se a conexão direta (db.<ref>.supabase.co) falhar por falta de IPv6,
# use o Session Pooler (aws-0-<regiao>.pooler.supabase.com, porta 5432,
# usuario postgres.<ref>), disponivel em Settings > Database no Supabase.
# ------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=db.SEU_PROJETO.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=SUA_SENHA_AQUI
DB_SSLMODE=require

# ------------------------------------------------------------------
# API de Reconhecimento Facial (FastAPI + DeepFace)
# FACIAL_API_FAKE=true simula a API para demonstracoes sem ela no ar
# ------------------------------------------------------------------
FACIAL_API_URL=http://host.docker.internal:7860
FACIAL_API_FAKE=true

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log
MAIL_MAILER=log
